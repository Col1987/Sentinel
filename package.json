{
  "name": "sentinel",
  "version": "0.1.0",
  "description": "AI-powered website testing framework",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --project=smoke",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\" \"playwright.config.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\" \"*.ts\"",
    "audit": "playwright test --project=audit",
    "discover": "playwright test --project=audit --grep @discovery",
    "review": "tsx scripts/review-diff.ts"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.45.0",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "tsx": "^4.23.1",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "googleapis": "^173.0.0"
  }
}
