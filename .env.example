# Admin credentials for Sentinel admin panel tests.
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit credentials.

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password

# Gmail API credentials for inbox verification in LIVE_MODE e2e tests.
# These allow Sentinel to read the sentinelqa2026@gmail.com inbox and confirm
# that verification emails arrive and contain the correct domain link.
#
# How to generate:
#   1. Go to https://console.cloud.google.com and create/select a project.
#   2. Enable the Gmail API under APIs & Services > Library.
#   3. Create OAuth 2.0 credentials (type: Web application) under
#      APIs & Services > Credentials. Add https://developers.google.com/oauthplayground
#      as an authorised redirect URI.
#   4. Go to https://developers.google.com/oauthplayground
#      > Settings (gear icon) > check "Use your own OAuth credentials"
#      > enter the Client ID and Client Secret from step 3.
#   5. In Step 1, find "Gmail API v1" and select the scope:
#      https://www.googleapis.com/auth/gmail.readonly
#   6. Click "Authorise APIs" and sign in as sentinelqa2026@gmail.com.
#   7. In Step 2, click "Exchange authorisation code for tokens".
#      Copy the Refresh Token — it does not expire unless revoked.
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token
